cyberlink.weighthint	0.95

cyberlink.targetid	cyboquatics.ceim.kernel.v1
cyberlink.relation	constrains
cyberlink.weighthint	0.95

cyberlink.targetid	cyboquatics.ker.evaluator.v1
cyberlink.relation	constrains
cyberlink.weighthint	0.95

cyberlink.targetid	nanoswarm.compliance.field.v1
cyberlink.relation	aligned-with
cyberlink.weighthint	0.98

