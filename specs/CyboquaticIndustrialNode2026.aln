spec CyboquaticIndustrialNode2026 v1.0.0
  role IndustrialNode
  path qpudatashards/CyboquaticIndustrialNode2026v1.csv

fields
  node_id
  timestamp_utc
  // raw measurements
  flow_m3_s
  cin_mg_l
  cout_mg_l
  electrical_kwh
  net_kg_co2e
  t90_days
  r_tox
  r_micro
  r_leach_cec
  r_pfas_resid
  r_hydraulic
  r_biology
  r_uncertainty
  // normalized risks
  r_energy
  r_carbon
  r_materials
  r_energy_hard
  r_carbon_hard
  r_materials_hard
  // Lyapunov residuals
  vt_prev
  vt_next
  // KER window
  k_knowledge
  e_eco_impact
  r_risk_of_harm
  ker_deployable
  // workload outputs
  duty_scale
  safestep_decision
  // governance
  spec_hash
  hexstamp
  notes

corridors
  // energy J/kg pollutant removed.[file:1]
  energy_safe_max      5.0e6
  energy_gold_max      1.0e7
  energy_hard_max      2.0e7

  // carbon net kg CO2e per cycle (negative = sequestration).[file:13]
  carbon_safe_max      0.0
  carbon_gold_max      0.5
  carbon_hard_max      1.0

  // material decay t90 in days.[file:13][file:21]
  t90_safe_max         90.0
  t90_gold_max         120.0
  t90_hard_max         180.0

  // KER thresholds.[file:1][file:13]
  K_min                0.90
  E_min                0.90
  R_max                0.13

kernels
  // Normalization must mirror cyboquatic_ecosafety_core.[file:13][file:21]
  risk_energy   = normalize_energy(flow_m3_s, cin_mg_l, cout_mg_l, electrical_kwh,
                                   energy_safe_max, energy_gold_max, energy_hard_max)
  risk_carbon   = normalize_carbon(net_kg_co2e,
                                   carbon_safe_max, carbon_gold_max, carbon_hard_max)
  risk_material = normalize_materials(t90_days, r_tox, r_micro, r_leach_cec, r_pfas_resid,
                                      t90_safe_max, t90_gold_max, t90_hard_max)

  vt_next_calc  = lyapunov_residual(risk_energy, r_hydraulic, r_biology,
                                    risk_carbon, risk_material, r_uncertainty)

  k_calc, e_calc, r_calc = ker_window(vt_prev, vt_next_calc, risk_energy,
                                      r_hydraulic, r_biology,
                                      risk_carbon, risk_material, r_uncertainty)

admissibility
  gate1_vt   : vt_next <= vt_prev + 1.0e-3
  gate2_r    : r_calc <= R_max
  gate3_ker  : k_calc >= K_min && e_calc >= E_min
  gate4_mats : t90_days <= t90_hard_max
               && r_tox    <= 0.10
               && r_micro  <= 0.05
               && r_leach_cec <= 0.10
               && r_pfas_resid <= 0.10

write_policy
  if gate1_vt && gate2_r then
    vt_next   = vt_next_calc
    r_energy  = risk_energy
    r_carbon  = risk_carbon
    r_materials = risk_material
    k_knowledge  = k_calc
    e_eco_impact = e_calc
    r_risk_of_harm = r_calc
    ker_deployable = (gate3_ker && gate4_mats)
  else
    reject_row

signature
  spec_hash = sha256(spec_body)
  hexstamp  = sign(spec_hash, "bostrom18sd2ujv24ual9c9pshtxys6j8knh6xaead9ye7")
