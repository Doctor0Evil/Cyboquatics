invariant kerdeployable v2.0.0

purpose
  Extends kerdeployable to include r_calib and r_sigma as first-class
  risk coordinates that participate in R, Vt, and can independently
  block deployment via data-quality trust.

requires
  EcoNetSchemaShard2026 v1.0.0
  CyboquaticEcosafetyCoreV2

riskvector_channels
  ch0  r_energy       w=1.0   hard=0.13
  ch1  r_hydraulic    w=1.0   hard=0.13
  ch2  r_biology      w=1.2   hard=0.13
  ch3  r_carbon       w=1.3   hard=0.13
  ch4  r_materials    w=1.1   hard=0.13
  ch5  r_calib        w=0.8   hard=0.13
  ch6  r_sigma        w=0.8   hard=0.13

residual
  Vt = sum_j ( w_j * r_j^2 ) for j in {ch0..ch6}

safestep
  epsilon        = 1e-6
  vt_ceiling     = 0.13

  condition Vt_next <= Vt_prev + epsilon
  condition Vt_next <= vt_ceiling
  condition max( r_j for j in {ch0..ch6} ) <= 0.13

ker_gates
  K_min  = 0.90
  E_min  = 0.90
  R_max  = 0.13

trust_channels
  Dt_sensor = 1.0 - r_sigma
  Dt_data   = 1.0 - r_calib
  Dt_combined = clamp( Dt_sensor * Dt_data, 0.0, 1.0 )

ker_adjusted
  K_adj = K_raw * Dt_combined
  E_adj = E_raw * Dt_combined
  R_adj = R_raw

invariant KERDeployableWithCalib.v2.1
  for row in QpuDataShardRow
    if row.deploydecision.lane == "PROD" then
      assert row.kerwindow.K_adj       >= 0.90
      assert row.kerwindow.E_adj       >= 0.90
      assert row.kerwindow.R_maxcoord  <= 0.13
      assert row.r_calib               <= r_calib_hard_max
      assert row.r_sigma               <= r_sigma_hard_max
      assert row.deploydecision.kerdeployable == true
    endif
  endfor
endinvariant

deploy_decision
  if r_calib > r_calib_hard_max then BlockedByCalib
  else if r_sigma > r_sigma_hard_max then BlockedByCalib
  else if R_adj > R_max then BlockedByRisk
  else if K_adj < K_min then BlockedByKER
  else if E_adj < E_min then BlockedByKER
  else Deploy

kerupgradeok
  condition K_new >= K_old
  condition E_new >= E_old
  condition R_new <= R_old
